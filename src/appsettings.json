{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug",
      "OllamaLiteLLMProxy": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "ollama": {
        "ClusterId": "ollamaCluster",
        "Match": {
          "Path": "/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeader": "Authorization", "Set": "Bearer sk-1234" }
        ]
      }
    },
    "Clusters": {
      "ollamaCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://192.168.0.106:4000/"
          }
        }
      }
    }
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 2147483648,
      "KeepAliveTimeout": "00:10:00",
      "RequestHeadersTimeout": "00:10:00"
    },

    "Endpoints": {

      "Http": {
        "Url": "http://localhost:11434"

      }
    }
  }
}
